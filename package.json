{
  "name": "familie-tilbake-frontend",
  "version": "0.0.1",
  "main": "node_dist/server.js",
  "author": "Nav - tilbake",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "NODE_ENV=production node --loader ts-node/esm --es-module-specifier-resolution=node node_dist/backend/server.js",
    "start:dev": "tsc && NODE_ENV=development node --loader ts-node/esm --es-module-specifier-resolution=node node_dist/backend/server.js",
    "build": "pnpm lint && pnpm build:prod",
    "build:client": "vite build --config src/frontend/vite.config.js",
    "build:server": "tsc --project tsconfig.json",
    "build:prod": "pnpm build:server && pnpm build:client",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p src/frontend/tsconfig.json",
    "lint": "eslint './src/**/*.{js,jsx,ts,tsx}'",
    "lint:fix": "eslint './src/**/*.{js,jsx,ts,tsx}' --fix",
    "prepare": "husky",
    "generate-types": "openapi-ts"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx},!src/frontend/generated/**": [
      "prettier --write",
      "eslint --fix src/ --max-warnings=0"
    ]
  },
  "dependencies": {
    "@grafana/faro-web-sdk": "2.6.3",
    "@hookform/resolvers": "5.2.2",
    "@navikt/aksel-icons": "8.10.5",
    "@navikt/ds-css": "8.10.5",
    "@navikt/ds-react": "8.10.5",
    "@navikt/ds-tailwind": "8.10.5",
    "@sentry/browser": "10.53.1",
    "@sentry/core": "10.53.1",
    "@tanstack/react-query": "5.100.10",
    "axios": "1.16.1",
    "classnames": "2.5.1",
    "compression": "1.8.1",
    "connect-redis": "9.0.0",
    "constate": "3.3.3",
    "cookie-parser": "1.4.7",
    "countries-list": "3.3.0",
    "date-fns": "4.1.0",
    "deep-equal": "2.2.3",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-session": "1.19.0",
    "express-static-gzip": "3.0.1",
    "http-proxy-middleware": "4.0.0",
    "prom-client": "15.1.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.75.0",
    "react-router": "7.15.1",
    "redis": "5.12.1",
    "tailwindcss": "4.3.0",
    "winston": "3.19.0",
    "zod": "4.4.3",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@axe-core/react": "4.11.3",
    "@eslint-react/eslint-plugin": "5.7.8",
    "@eslint/js": "10.0.1",
    "@hey-api/openapi-ts": "^0.97.1",
    "@peculiar/webcrypto": "1.7.1",
    "@sentry/vite-plugin": "5.3.0",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/compression": "1.8.1",
    "@types/cookie-parser": "1.4.10",
    "@types/deep-equal": "1.0.4",
    "@types/express": "5.0.6",
    "@types/express-session": "1.19.0",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.4",
    "prettier": "3.8.3",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vite": "8.0.13",
    "vite-plugin-compression": "0.5.1",
    "vitest": "4.1.6"
  },
  "packageManager": "pnpm@11.0.4"
}
