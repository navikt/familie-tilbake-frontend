{
  "name": "familie-tilbake-frontend",
  "version": "0.0.1",
  "main": "node_dist/server.js",
  "author": "Nav - tilbake",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "NODE_ENV=production node --loader ts-node/esm --es-module-specifier-resolution=node node_dist/backend/server.js",
    "start:dev": "tsc && NODE_ENV=development node --loader ts-node/esm --es-module-specifier-resolution=node node_dist/backend/server.js",
    "build": "pnpm check && pnpm build:prod",
    "build:client": "vite build --config src/frontend/vite.config.js",
    "build:server": "tsc --project tsconfig.json",
    "build:prod": "pnpm build:server && pnpm build:client",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p src/frontend/tsconfig.json",
    "check": "biome check src",
    "check:fix": "biome check --write src",
    "prepare": "husky",
    "generate-types": "openapi-ts"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true --error-on-warnings"
    ]
  },
  "dependencies": {
    "@grafana/faro-web-sdk": "2.8.2",
    "@hookform/resolvers": "5.4.0",
    "@navikt/aksel-icons": "8.14.0",
    "@navikt/ds-css": "8.14.0",
    "@navikt/ds-react": "8.14.0",
    "@navikt/ds-tailwind": "8.14.0",
    "@sentry/browser": "10.63.0",
    "@sentry/core": "10.63.0",
    "@tanstack/react-query": "5.101.2",
    "axios": "1.18.1",
    "compression": "1.8.1",
    "connect-redis": "9.0.0",
    "constate": "4.0.0",
    "cookie-parser": "1.4.7",
    "countries-list": "3.3.0",
    "date-fns": "4.4.0",
    "deep-equal": "2.2.3",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-session": "1.19.0",
    "express-static-gzip": "3.0.1",
    "http-proxy-middleware": "4.1.1",
    "prom-client": "15.1.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.80.0",
    "react-router": "8.1.0",
    "redis": "6.1.0",
    "tailwindcss": "4.3.2",
    "winston": "3.19.0",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@axe-core/react": "4.12.1",
    "@biomejs/biome": "2.5.2",
    "@hey-api/openapi-ts": "0.99.0",
    "@peculiar/webcrypto": "1.7.1",
    "@sentry/vite-plugin": "5.3.0",
    "@tailwindcss/vite": "4.3.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/compression": "1.8.1",
    "@types/cookie-parser": "1.4.10",
    "@types/deep-equal": "1.0.4",
    "@types/express": "5.0.6",
    "@types/express-session": "1.19.0",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.8",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vite-plugin-compression": "0.5.1",
    "vitest": "4.1.9"
  },
  "packageManager": "pnpm@11.0.4"
}
